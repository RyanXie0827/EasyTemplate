<idea-plugin>
    <id>com.github.ryanxie0827.easytemplate</id>
    <name>EasyTemplate</name>
    <vendor url="https://github.com/ryanxie0827/EasyTemplate">ryanxie0827</vendor>

    <description><![CDATA[
      EasyTemplate - 全自动同步全栈开发模板。
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.github.ryanxie0827.easytemplate.TemplateStartupActivity"/>
    </extensions>

    <actions>
        <action id="com.github.ryanxie0827.easytemplate.SetupAction"
                class="com.github.ryanxie0827.easytemplate.SetupTemplatesAction"
                text="Sync EasyTemplate"
                description="手动执行模板同步">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>